NODE_ENV=development
# Bind address for the API server. Loopback by default; a deployment opts into a
# specific interface (or 0.0.0.0) explicitly.
HOST=127.0.0.1
PORT=3000

# Read-scope GitHub token the server authenticates GitHub reads with.
# Optional; unauthenticated reads work but are rate-limited.
GITHUB_TOKEN=
# Comma-separated owner/name repos to watch. Defaults to acme/board-review.
WATCHED_REPOS=acme/board-review

# Durable local source of truth for retained review rounds and feedback.
REVIEW_STATE_PATH=.data/review-state.json

VITE_API_URL=http://localhost:3000
