# Copy this file to the gitignored root .env and replace both operator inputs
# before starting Compose. The service fixes the other values explicitly.
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Read-scope GitHub token used only for GitHub reads.
GITHUB_TOKEN=
# Comma-separated real owner/name repositories. Production rejects an omission.
WATCHED_REPOS=

# The named volume mounts all of /data so the state file and its atomic temporary
# replacement are on the same filesystem.
REVIEW_STATE_PATH=/data/review-state.json
