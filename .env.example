# Copy this file to the gitignored root .env and replace the example repository
# names and owner keys before starting Compose. The service fixes the other values.
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Comma-separated owner/name repositories. Production requires one credential for
# every distinct owner. Normalize an owner by uppercasing it and replacing hyphens
# with underscores in GITHUB_TOKEN_<NORMALIZED_OWNER>.
WATCHED_REPOS=owner-one/document-repo,owner-two/document-repo
GITHUB_TOKEN_OWNER_ONE=
GITHUB_TOKEN_OWNER_TWO=

# The named volume mounts all of /data so the state file and its atomic temporary
# replacement are on the same filesystem.
REVIEW_STATE_PATH=/data/review-state.json
